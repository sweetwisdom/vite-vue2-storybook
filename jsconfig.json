{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "baseUrl": "./",
    "allowJs": true,
    "moduleResolution": "node",
    "jsx": "preserve",
    "paths": {
      "@static": ["public/*"],
      "@/*": ["src/*"]
    },
    "lib": ["esnext", "dom", "dom.iterable", "scripthost"]
  },
  "vueCompilerOptions": {
    "target": 2.7
  }
}
